## 4. Database Schema Design

### 4.1 Entity-Relationship Diagram

```mermaid
erDiagram
    USERS ||--o{ LEAVE_REQUESTS : submits
    USERS ||--o{ NOTIFICATIONS : receives
    USERS }o--|| DEPARTMENTS : belongs_to
    USERS }o--|| ROLES : has
    DEPARTMENTS ||--o{ USERS : contains
    LEAVE_TYPES ||--o{ LEAVE_REQUESTS : categorizes
    LEAVE_TYPES ||--o{ LEAVE_BALANCES : defines
    USERS ||--o{ LEAVE_BALANCES : has
    LEAVE_POLICIES ||--o{ LEAVE_TYPES : governs
    HOLIDAYS ||--o{ LEAVE_REQUESTS : affects

    USERS {
        uuid id PK
        string email UK
        string password_hash
        string first_name
        string last_name
        string phone
        string avatar_url
        uuid department_id FK
        uuid role_id FK
        uuid manager_id FK
        date joined_date
        boolean is_active
        timestamp created_at
        timestamp updated_at
    }

    ROLES {
        uuid id PK
        string name UK
        jsonb permissions
    }

    DEPARTMENTS {
        uuid id PK
        string name UK
        string description
        uuid head_id FK
        boolean is_active
    }

    LEAVE_TYPES {
        uuid id PK
        string name UK
        string description
        string color
        int default_days
        boolean is_paid
        boolean requires_document
        boolean is_active
    }

    LEAVE_REQUESTS {
        uuid id PK
        uuid user_id FK
        uuid leave_type_id FK
        date start_date
        date end_date
        float total_days
        string reason
        string status
        uuid approved_by FK
        string rejection_reason
        string[] attachments
        timestamp applied_at
        timestamp actioned_at
        timestamp created_at
    }

    LEAVE_BALANCES {
        uuid id PK
        uuid user_id FK
        uuid leave_type_id FK
        int year
        float total_allocated
        float used
        float pending
        float carried_over
        float remaining
    }

    LEAVE_POLICIES {
        uuid id PK
        string name
        jsonb accrual_rules
        jsonb carry_over_rules
        jsonb encashment_rules
        boolean is_default
    }

    HOLIDAYS {
        uuid id PK
        string name
        date date
        string type
        boolean is_optional
        int year
    }

    NOTIFICATIONS {
        uuid id PK
        uuid user_id FK
        string type
        string title
        string message
        jsonb metadata
        boolean is_read
        timestamp created_at
    }

    AUDIT_LOG {
        uuid id PK
        uuid user_id FK
        string action
        string entity_type
        uuid entity_id
        jsonb old_values
        jsonb new_values
        string ip_address
        timestamp created_at
    }
```

